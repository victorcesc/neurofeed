# Copy to .env and export before run, or use a shell wrapper.
# Never commit .env with real secrets.

# NEUROFEED_HTTP_TIMEOUT=30s
# NEUROFEED_HTTP_TIMEOUT_SECONDS=
# NEUROFEED_LLM_TIMEOUT=60s

# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# Single feed (tier defaults to news; optional RSS_FEED_TIER=primary|expert|news|community):
# RSS_FEED_URL=
# RSS_FEED_TIER=

# Multiple feeds (JSON array; when set, overrides RSS_FEED_URL for ingestion):
# NEUROFEED_RSS_FEEDS=[{"url":"https://example.com/feed.xml","tier":"primary"},{"url":"https://other.org/atom.xml","tier":"expert"}]
