# Copy to .env and export before run, or use a shell wrapper.
# Never commit .env with real secrets.

# NEUROFEED_HTTP_TIMEOUT=30s
# NEUROFEED_HTTP_TIMEOUT_SECONDS=
# NEUROFEED_LLM_TIMEOUT=60s
# NEUROFEED_LLM_MAX_ARTICLES=12   # with multiple RSS "subject" labels, sampling is round-robin per subject up to this cap
# NEUROFEED_LLM_MAX_OUTPUT_TOKENS=2500
# NEUROFEED_RSS_ITEMS_PER_FEED=2  # per feed URL: keep only the N newest items (pubDate/updated); 0 = keep all items from each feed

# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# Single feed (tier defaults to news; optional RSS_FEED_TIER=primary|expert|news|community; optional RSS_FEED_SUBJECT=section label for digest grouping):
# RSS_FEED_URL=
# RSS_FEED_TIER=
# RSS_FEED_SUBJECT=

# Multiple feeds (JSON array; when set, overrides RSS_FEED_URL for ingestion). Optional per-feed "subject" (≤64 chars) groups items into labeled sections in the digest:
# NEUROFEED_RSS_FEEDS=[{"url":"https://example.com/feed.xml","tier":"primary","subject":"AI"},{"url":"https://other.org/atom.xml","tier":"expert","subject":"Tech"}]
#
# Example with four subjects (AI, NBA, Futebol, Tech) — copy one line into your .env:
# NEUROFEED_RSS_FEEDS='[{"url":"https://openai.com/news/rss.xml","tier":"primary","subject":"AI"},{"url":"https://www.technologyreview.com/topic/artificial-intelligence/feed/","tier":"news","subject":"AI"},{"url":"https://arxiv.org/rss/cs.AI","tier":"expert","subject":"AI"},{"url":"https://huggingface.co/blog/feed.xml","tier":"primary","subject":"AI"},{"url":"https://simonwillison.net/categories/ai/feed/","tier":"expert","subject":"AI"},{"url":"https://github.blog/category/ai/feed/","tier":"news","subject":"AI"},{"url":"https://www.espn.com/espn/rss/nba/news","tier":"news","subject":"NBA"},{"url":"http://www.basketballinsiders.com/feed/","tier":"expert","subject":"NBA"},{"url":"https://www.theringer.com/nba/rss/index.xml","tier":"community","subject":"NBA"},{"url":"https://push.api.bbci.co.uk/morph/data/bbc-morph-feeds-results-zones-mens-football/format/rss","tier":"news","subject":"Futebol"},{"url":"https://www.goal.com/en/feeds/news","tier":"news","subject":"Futebol"},{"url":"https://www.theguardian.com/football/rss","tier":"expert","subject":"Futebol"},{"url":"https://www.theverge.com/rss/index.xml","tier":"news","subject":"Tech"},{"url":"https://techcrunch.com/feed/","tier":"news","subject":"Tech"},{"url":"https://news.ycombinator.com/rss","tier":"community","subject":"Tech"}]'
